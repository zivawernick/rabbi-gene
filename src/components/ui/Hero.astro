---
import { Image } from 'astro:assets'

import SocialIcons from '@/components/ui/SocialIcons.astro'


const {fullName, shortName, slogan, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    Welcome! I'm <span class='text-secondary'>{shortName}</span>
  </h1>
  <h2 class='text-3xl font-normal mb-8'> {slogan}
  </h2>
  <p class='text-lg mb-6'>
    Gene Wernick is a Rabbi with a passion for education, scholarship and community. Rabbi Wernick has just completed his latest book: "Antisemitism and the Tribe."  It will be available on this web site.  It traces the history of the Jews as an extended family that defies classification as a nation or religion but people united by ancestral ties and beyond common ways of looking at the world distinguished for their independent thought."
    Rabbi Wernick is available for guest lectures, pastorial care and life-cycle events in New York City or online.
  </p>
  <div class='flex gap-4'>
    <SocialIcons />
  </div>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle size-44'
  />
</div>
