---
import {template} from  '../../settings.ts'
---

<label class="toggle text-base-content" transition:persist>
  <input
    type="checkbox"
    value={template.darkTheme}
    class="theme-controller"
    id="theme-toggle"
    aria-label="Toggle theme"
/>
  <svg
    aria-label="Sun"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24">
    <g
      stroke-linejoin="round"
      stroke-linecap="round"
      stroke-width="2"
      fill="none"
      stroke="currentColor">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </g>
  </svg>
  <svg
    aria-label="Moon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none">
    <g
      stroke-linejoin="round"
      stroke-linecap="round"
      stroke-width="2"
      fill="none"
      stroke="currentColor">
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </g>
  </svg>
</label>
<script is:inline define:vars={{ darkTheme: template.darkTheme, lightTheme: template.lightTheme }}>
  {
    const initToggle = () => {
      const toggle = document.getElementById('theme-toggle');
      if (!toggle) return;

      const currentTheme = localStorage.getItem('theme') || lightTheme;
      toggle.checked = currentTheme === darkTheme;

      toggle.onchange = (e) => {
        const theme = e.target.checked ? darkTheme : lightTheme;
        localStorage.setItem('theme', theme);
        document.documentElement.setAttribute('data-theme', theme);
      };
    };

    initToggle();
    document.addEventListener('astro:after-swap', initToggle);
  }
</script>
